generator client {
  provider      = "prisma-client-js"
  output        = "../src/database/generated/client"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Warehouse {
  id          String            @id @default(uuid())
  name        String
  location    String
  capacity    Int
  alerts      Alert[]
  forecasts   ForecastHistory[]
  inventories Inventory[]
  orders      Order[]
}

model Product {
  id          String            @id @default(uuid())
  name        String
  description String?
  price       Decimal
  createdAt   DateTime          @default(now())
  alerts      Alert[]
  forecasts   ForecastHistory[]
  inventories Inventory[]
  orders      Order[]
}

model Inventory {
  id          String    @id @default(uuid())
  warehouseId String
  productId   String
  stock       Int
  minStock    Int
  maxStock    Int
  lastUpdated DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
}

model Customer {
  id      String  @id @default(uuid())
  name    String
  email   String  @unique
  address String
  orders  Order[]
}

model Order {
  id          String      @id @default(uuid())
  customerId  String?
  productId   String
  warehouseId String
  quantity    Int
  totalPrice  Decimal
  status      OrderStatus
  createdAt   DateTime    @default(now())
  customer    Customer?   @relation(fields: [customerId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id])
  trackings   Tracking[]
}

model Tracking {
  id          String         @id @default(uuid())
  orderId     String
  status      TrackingStatus
  location    String?
  updatedAt   DateTime       @default(now())
  delayReason String?
  order       Order          @relation(fields: [orderId], references: [id])
}

model ForecastHistory {
  id            String    @id @default(uuid())
  productId     String
  warehouseId   String
  createdAt     DateTime  @default(now())
  forecastDate  DateTime
  forecastYhat  Float
  forecastLower Float
  forecastUpper Float
  product       Product   @relation(fields: [productId], references: [id])
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
}

model Alert {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  type        AlertType
  message     String
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
}

enum OrderStatus {
  Pending
  Processing
  Shipped
  Delivered
  Cancelled
}

enum TrackingStatus {
  Processing
  InTransit
  Delivered
  Delayed
}

enum AlertType {
  LowStock
  OutOfStock
}
